# ====================================
# Application Configuration
# ====================================
NODE_ENV=development
PORT=3001

# ====================================
# Frontend Configuration
# ====================================
NEXT_PUBLIC_API_URL=http://localhost:3002/api
NEXT_PUBLIC_BASE_URL=
NEXT_PUBLIC_BASE_PATH=

# ====================================
# Database Configuration
# ====================================
# Local Development
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=asteris_db
DB_SSL=false

# Production (Railway)
# DB_HOST=${PGHOST}
# DB_PORT=${PGPORT}
# DB_USER=${PGUSER}
# DB_PASSWORD=${PGPASSWORD}
# DB_NAME=${PGDATABASE}
# DB_SSL=true

# ====================================
# Stripe Configuration
# ====================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_API_VERSION=2022-11-15
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# ====================================
# JWT Configuration
# ====================================
JWT_SECRET=your_secure_jwt_secret_here
JWT_EXPIRES_IN=30d

# ====================================
# CORS Configuration
# ====================================
CORS_ORIGIN=http://localhost:3000,https://asteris-ai.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,https://asteris-ai.vercel.app

# ====================================
# Logging
# ====================================
LOG_LEVEL=info
LOG_FORMAT=combined

# ====================================
# Security
# ====================================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX=100  # Max requests per window

# ====================================
# Production Overrides (uncomment for production)
# ====================================
# NODE_ENV=production
# PORT=${PORT}
# CORS_ORIGIN=https://asteris-ai.vercel.app
# ALLOWED_ORIGINS=https://asteris-ai.vercel.app
