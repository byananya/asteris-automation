# ====================================
# Railway Deployment Configuration
# ====================================
# Copy this file to .env for local development
# For Railway, set these variables in your project settings
# ====================================

# API Configuration
# In production, set to your Railway URL (e.g., https://your-project-name.up.railway.app)
API_BASE_URL=http://localhost:3002
API_KEY=your_stripe_secret_key_here

# Database Configuration (Railway will provide these)
DB_HOST=your-db-host
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=railway
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Server Configuration
PORT=3002
NODE_ENV=production

# Logging
LOG_LEVEL=info

# CORS Configuration (update with your frontend URL)
CORS_ORIGIN=http://localhost:3000

# Session Configuration
SESSION_SECRET=your-session-secret

# Stripe Configuration (for production)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret

# ====================================
# Required for Railway Deployment
# ====================================
# 1. In Railway dashboard, go to your project
# 2. Click on 'Variables' tab
# 3. Add all the above variables
# 4. For database, Railway will automatically provide:
#    - DATABASE_URL
#    - PG* variables
# ====================================
