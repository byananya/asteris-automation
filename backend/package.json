{
  "name": "@asteris/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --exec tsx src/index.ts",
    "build": "tsc",
    "start": "NODE_ENV=production node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "train": "tsx src/ml/training/train.ts",
    "test": "NODE_ENV=test jest",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:coverage": "NODE_ENV=test jest --coverage",
    "postinstall": "npm rebuild @tensorflow/tfjs-node --build-from-source=false"
  },
  "type": "commonjs",
  "dependencies": {
    "@tensorflow-models/universal-sentence-encoder": "^1.3.3",
    "@tensorflow/tfjs-core": "^4.10.0",
    "@tensorflow/tfjs-node": "^4.10.0",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^4.18.2",
    "express-validator": "^7.2.1",
    "natural": "^6.5.0",
    "pg": "^8.11.0",
    "stripe": "^18.2.0",
    "typeorm": "^0.3.16",
    "typescript": "^5.8.3",
    "winston": "^3.17.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json",
      "node"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/test/setupTests.ts"
    ],
    "moduleNameMapper": {
      "^\\.\\./utils/logger\\.js$": "<rootDir>/test/__mocks__/logger.ts",
      "^(\\.\\./\\.\\./src/.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ]
  },
  "devDependencies": {
    "@faker-js/faker": "^9.8.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/date-fns": "^2.5.3",
    "@types/express": "^4.17.23",
    "@types/express-serve-static-core": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/natural": "^5.1.5",
    "@types/node": "^20.19.1",
    "@types/pg": "^8.15.4",
    "@types/stripe": "^8.0.416",
    "@types/uuid": "^10.0.0",
    "@types/winston": "^2.4.4",
    "jest": "^29.7.0",
    "nodemon": "^2.0.22",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3"
  }
}
