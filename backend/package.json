{
  "name": "@asteris/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--loader ts-node/esm' nodemon src/index.ts",
    "build": "tsc -p tsconfig.deploy.json",
    "start": "node dist/index.js",
    "train": "node --loader ts-node/esm src/ml/training/train.ts",
    "postinstall": "npm rebuild @tensorflow/tfjs-node --build-from-source=false"
  },
  "dependencies": {
    "@tensorflow-models/universal-sentence-encoder": "1.3.3",
    "@tensorflow/tfjs-core": "4.10.0",
    "@tensorflow/tfjs-node": "4.10.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^4.18.2",
    "express-validator": "^7.2.1",
    "natural": "^6.5.0",
    "pg": "^8.11.0",
    "stripe": "^18.2.0",
    "typeorm": "^0.3.16"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.17",
    "@types/natural": "^5.1.5",
    "@types/node": "^20.19.0",
    "@types/stripe": "^8.0.416",
    "nodemon": "^2.0.22",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
