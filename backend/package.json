{
  "name": "@asteris/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc && npm run copy-assets",
    "start:backend": "NODE_ENV=production node dist/index.js",
    "start:frontend": "NODE_ENV=production node /app/frontend/standalone/server.js",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"", 
    "start:prod": "NODE_ENV=production node dist/index.js",
    "train": "ts-node src/ml/training/train.ts",
    "postinstall": "npm rebuild @tensorflow/tfjs-node --build-from-source=false"
  },
  "dependencies": {
    "@tensorflow-models/universal-sentence-encoder": "^1.3.3",
    "@tensorflow/tfjs-core": "^4.10.0",
    "@tensorflow/tfjs-node": "^4.10.0",
    "axios": "^1.9.0",
    "concurrently": "^9.2.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^4.18.2",
    "express-validator": "^7.2.1",
    "natural": "^6.5.0",
    "pg": "^8.11.0",
    "stripe": "^18.3.0",
    "typeorm": "^0.3.16",
    "typescript": "^5.8.3",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.8.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/express-serve-static-core": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/natural": "^5.1.5",
    "@types/node": "^20.19.0",
    "@types/stripe": "^8.0.416",
    "@types/uuid": "^10.0.0",
    "@types/winston": "^2.4.4",
    "jest": "^29.7.0",
    "nodemon": "^2.0.22",
    "ts-node": "^10.9.2"
  }
}
