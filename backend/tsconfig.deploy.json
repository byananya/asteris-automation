{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "strict": false,
    "noEmit": false,
    "outDir": "dist",
    "allowJs": true,
    "checkJs": false,
    "paths": {
      "@tensorflow/*": ["./node_modules/@tensorflow/*"],
      "@tensorflow-models/*": ["./node_modules/@tensorflow-models/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules", 
    "**/*.test.ts",
    "src/ml/models/**/*.ts"
  ]
}
